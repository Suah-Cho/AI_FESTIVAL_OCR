# 실행 환경: dev(외부 API 직접 호출) | prod(Keycloak + VAIV /api/chat)
APP_ENV=dev

# --- dev: 외부 API 직접 호출 ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_VISION_MODEL=gpt-4o

# dev 멀티 모델 — 같은 API 키로 모델만 여러 개 (다수결 병합)
# OCR_MODEL_NAMES=gpt-4o,gpt-4o-mini
# OCR_MODEL_TYPE=openai
#
# dev 멀티 API — 슬롯마다 다른 제공자/키/URL 지정 가능
# OCR_MODEL_1_MODEL=gpt-4o
# OCR_MODEL_1_API_KEY=sk-openai-key
# OCR_MODEL_2_MODEL=gemini-1.5-pro
# OCR_MODEL_2_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OCR_MODEL_2_API_KEY=goog-api-key

# --- prod: Keycloak + VAIV OCR (APP_ENV=prod 일 때) ---
# PROD_API_GATEWAY_URL=https://devllm-api.xhub.co.kr/api/chat
#
# 운영 멀티 모델 — MODEL 이름만 나열 (URL/Keycloak/헤더는 공통, 다수결 병합)
# OCR_MODEL_NAMES=qwen3.5:35b,gemma4:31b,qwen3.6:35b-a3b,qwen2.5vl:32b
# OCR_MODEL_TYPE=vaiv
#
# 또는 슬롯별 지정 (MODEL만 다르게):
# OCR_MODEL_1_MODEL=qwen3.5:35b
# OCR_MODEL_2_MODEL=gemma4:31b
# OCR_MODEL_3_MODEL=qwen2.5vl:32b
#
# Keycloak (password grant)
# KEYCLOAK_TOKEN_URL=https://pass.xhub.co.kr/realms/ollama-devs-apis/protocol/openid-connect/token
# KEYCLOAK_CLIENT_ID=ollama-devs-apis-client
# KEYCLOAK_CLIENT_SECRET=your-client-secret
# KEYCLOAK_USERNAME=your-username
# KEYCLOAK_PASSWORD=your-password
# KEYCLOAK_GRANT_TYPE=password
#
# VAIV 게이트웨이 필수 헤더
# PROD_LLM_CODE_COMPANY=HDS
# PROD_LLM_CODE_SERVICE=image2text
# PROD_LLM_TIMEOUT=300
# PROD_LLM_MAX_TOKENS=4096
# PROD_LLM_MAX_RETRIES=2
# PROD_VAIV_THINK=0
#
# 이미지 전처리 (업스케일 + 미세 회전)
# PROD_IMAGE_PREPROCESS=1
# PROD_IMAGE_UPSCALE=1.5
# PROD_IMAGE_ROTATE=1.5

# 1로 설정하면 GPT 호출 없이 더미 추출기로 동작 (뼈대 테스트용)
# USE_DUMMY_EXTRACTOR=1

# 로그 레벨: DEBUG | INFO | WARNING (테스트 시 DEBUG 권장)
# LOG_LEVEL=INFO
