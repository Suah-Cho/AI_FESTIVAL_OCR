# =============================================================================
# AI_FESTIVAL_OCR 환경 변수
# 이 파일을 복사해 .env 를 만든 뒤 값을 채우세요.
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# 공통
# -----------------------------------------------------------------------------
# dev = OpenAI 등 외부 API 직접 호출
# prod = Keycloak + VAIV(사내 게이트웨이) 경유
APP_ENV=dev

LOG_LEVEL=INFO

# 병렬 처리 (검증·추출 동시 행/폴더 수)
# MAX_PARALLEL_ROWS=5

# 폴더당 LLM에 보낼 최대 이미지 수
# MAX_IMAGES_PER_FOLDER=8

# API 타임아웃(초)
# OPENAI_TIMEOUT=60

# 뼈대 테스트용 — 1 이면 LLM 호출 없이 더미 추출
# USE_DUMMY_EXTRACTOR=1

# 서류별 분리 추출 (사업자등록증/신분증 등 파일명·항목별 LLM 분리). 0=기존 일괄 추출
# USE_SPLIT_DOC_EXTRACTION=1


# =============================================================================
# dev — OpenAI 직접 호출 (APP_ENV=dev)
# =============================================================================

OPENAI_API_KEY=sk-your-key-here

# ★ 모델 이름은 반드시 1개만! (쉼표 넣으면 invalid model ID 오류)
OPENAI_VISION_MODEL=gpt-4o

# --- 모델 1개만 쓸 때 (위 OPENAI_VISION_MODEL 만 있으면 됨) ---
# OCR_MODEL_NAMES 는 비워 두세요.

# --- 모델 여러 개 + 다수결 병합 (정확도↑) ---
# OPENAI_VISION_MODEL=gpt-4o          ← fallback 용, 1개만
# OCR_MODEL_NAMES=gpt-4o,gpt-4o-mini  ← 여기에 쉼표로 나열
# OCR_MODEL_TYPE=openai

# --- 제공자마다 다른 키/URL 쓸 때 (고급) ---
# OCR_MODEL_1_MODEL=gpt-4o
# OCR_MODEL_1_API_KEY=sk-openai-key
# OCR_MODEL_2_MODEL=gemini-1.5-pro
# OCR_MODEL_2_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OCR_MODEL_2_API_KEY=goog-api-key


# =============================================================================
# prod — Keycloak + VAIV (APP_ENV=prod 일 때 위 dev OpenAI 설정은 무시됨)
# =============================================================================

# APP_ENV=prod
# LOG_LEVEL=INFO

# PROD_API_GATEWAY_URL=https://devllm-api.xhub.co.kr/api/chat

# 모델 여러 개 — 이름만 쉼표 나열 (게이트웨이·Keycloak 공통)
# OCR_MODEL_NAMES=qwen3.5:35b,gemma4:31b,qwen2.5vl:32b
# OCR_MODEL_TYPE=vaiv

# 또는 슬롯별 MODEL 지정
# OCR_MODEL_1_MODEL=qwen3.5:35b
# OCR_MODEL_2_MODEL=gemma4:31b

# Keycloak (password grant)
# KEYCLOAK_TOKEN_URL=https://pass.xhub.co.kr/realms/ollama-devs-apis/protocol/openid-connect/token
# KEYCLOAK_CLIENT_ID=ollama-devs-apis-client
# KEYCLOAK_CLIENT_SECRET=your-client-secret
# KEYCLOAK_USERNAME=your-username
# KEYCLOAK_PASSWORD=your-password
# KEYCLOAK_GRANT_TYPE=password

# VAIV 게이트웨이 필수 헤더
# PROD_LLM_CODE_COMPANY=HDS
# PROD_LLM_CODE_SERVICE=image2text
# PROD_LLM_TIMEOUT=300
# PROD_LLM_MAX_TOKENS=4096
# PROD_LLM_MAX_RETRIES=2
# PROD_VAIV_THINK=0

# 이미지 전처리 (prod VAIV)
# PROD_IMAGE_PREPROCESS=1
# PROD_IMAGE_UPSCALE=1.5
# PROD_IMAGE_ROTATE=1.5

# -----------------------------------------------------------------------------
# 검증 — 서류 위치 열 기본 이름 (화면에서 비워 두면 사용)
# 동의어(서류경로, 검증파일 등)는 app/services/field_aliases.py 에 정의
# -----------------------------------------------------------------------------
# DEFAULT_FOLDER_COL=파일폴더
# DEFAULT_FILE_NO_COL=파일번호

# -----------------------------------------------------------------------------
# Docker build / runtime — 프록시 (chatbot_frontend 와 동일: 호스트:포트 만 적기)
# -----------------------------------------------------------------------------
# HTTP_PROXY=proxy.example.com:8080
# HTTPS_PROXY=proxy.example.com:8080
# no_proxy=localhost,127.0.0.1,.example.com
# compose 가 build·runtime 모두 http:// 접두사를 붙여 전달합니다.

# 사내 PyPI 미러가 있으면:
# PIP_INDEX_URL=https://your-nexus/repository/pypi/simple
# PIP_TRUSTED_HOST=your-nexus

# 인터넷 전혀 없으면 wheelhouse 오프라인 빌드:
#   bash scripts/download_wheelhouse.sh   (인터넷 되는 PC)
#   scp -r wheelhouse 서버:~/AI_FESTIVAL_OCR/
# DOCKERFILE=Dockerfile.offline
